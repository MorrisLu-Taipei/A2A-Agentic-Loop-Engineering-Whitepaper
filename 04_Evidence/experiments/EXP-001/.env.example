# 複製成 .env 後填入。runner 只認通用 OpenAI 相容端點(不綁特定服務)。
# 開發模型 X 與驗證模型 Y 可指向不同端點/模型以測「異模型」效果。
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_API_KEY=sk-REPLACE_ME
MODEL_X=model-for-developer
MODEL_Y=model-for-verifier
TEMPERATURE=0.0
MAX_TOKENS=4096
# 全域預算 circuit breaker
BUDGET_USD_LIMIT=20
BUDGET_WALLCLOCK_MIN=60
